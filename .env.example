# Backend-only secrets (do not expose to frontend)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
PG_SSL_STRICT=false
JWT_SECRET=<minimum-32-character-random-secret>
JWT_EXPIRES_IN=12h
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_IDS=<optional-comma-separated-client-ids>
GOOGLE_AUTH_STRICT_AUDIENCE=false
HF_TOKEN=<hugging-face-token>
GITHUB_TOKEN=<optional-github-token>
APP_BASE_URL=https://your-app-domain.example
CORS_ORIGIN=https://your-frontend-domain.example
CORS_ORIGIN_EXTRA=<optional-comma-separated-extra-origins>
ALLOW_VERCEL_PREVIEW_ORIGINS=false
PORT=4000

# Security telemetry tuning
TRAFFIC_ALERT_THRESHOLD=300
AUTH_FAILURE_ALERT_THRESHOLD=20
